PORT=3000
NODE_ENV=development
REDIS_URL=redis://localhost:6379
TOTAL_CHECKBOXES=1000000

# Use a long random value in real deployments.
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=omc_sid
SESSION_TTL_SECONDS=604800

# Leave OIDC_ISSUER empty for local demo login.
# For Auth0/Okta/Keycloak/Google, set issuer/client values and register:
# http://localhost:3000/auth/callback
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
OIDC_SCOPE=openid email profile

# Custom HTTP limiter.
HTTP_RATE_WINDOW_MS=60000
HTTP_RATE_MAX=120

# Custom WebSocket toggle limiter.
WS_RATE_WINDOW_MS=10000
WS_RATE_MAX_PER_USER=40
WS_RATE_MAX_PER_SOCKET=25
WS_BAN_AFTER=90
WS_BAN_SECONDS=60
TOGGLE_BURST_LIMIT=2
TOGGLE_COOLDOWN_MS=5000
